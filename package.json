{
  "name": "xiaoshuo-ts-migration",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:workbench": "npm run dev -w @xiaoshuo/workbench",
    "dev:desktop": "node apps/desktop-shell/scripts/start-desktop.mjs",
    "build:workbench": "npm run build -w @xiaoshuo/shared && npm run build -w @xiaoshuo/workbench",
    "build:desktop": "npm run build -w @xiaoshuo/desktop-shell",
    "smoke:desktop": "npm run smoke -w @xiaoshuo/desktop-shell",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run build -w @xiaoshuo/shared && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "eval:routing": "vitest run packages/agent-runtime/src/routing-eval.test.ts",
    "eval:planning": "vitest run packages/agent-runtime/src/planner.test.ts",
    "eval:memory": "vitest run packages/agent-runtime/src/memory.test.ts",
    "eval:quality": "vitest run packages/agent-runtime/src/evaluator-registry.test.ts",
    "eval:recovery": "vitest run packages/agent-runtime/src/kernel/run-recovery.e2e.test.ts",
    "eval:security": "vitest run packages/agent-runtime/src/agent-loop.test.ts",
    "eval:excluded-capabilities": "vitest run packages/agent-runtime/src/negative-capability-policy.test.ts packages/agent-runtime/src/agent-loop.test.ts packages/agent-runtime/src/memory.test.ts apps/desktop-shell/src/preload/user-gesture-ticket.test.ts"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "pdf-parse": "^2.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
