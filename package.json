{
  "name": "xiaoshuo-ts-migration",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:workbench": "npm run dev -w @xiaoshuo/workbench",
    "dev:desktop": "node apps/desktop-shell/scripts/start-desktop.mjs",
    "build:workbench": "npm run build -w @xiaoshuo/shared && npm run build -w @xiaoshuo/workbench",
    "build:desktop": "npm run build -w @xiaoshuo/desktop-shell",
    "smoke:desktop": "npm run smoke -w @xiaoshuo/desktop-shell",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run build -w @xiaoshuo/shared && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "pdf-parse": "^2.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
